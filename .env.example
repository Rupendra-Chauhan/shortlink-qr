# Copy to .env and adjust. Required for createApp() / start() unless jwtSecret is passed in code.
JWT_SECRET=change-me-to-a-long-random-secret

# MongoDB (optional; defaults to mongodb://localhost:27017/url_shortner)
# MONGODB_URI=mongodb://localhost:27017/url_shortner

# Public URL used when building short links (optional)
# BASE_URL=https://your-domain.com

# Comma-separated browser origins allowed by CORS (optional; if unset, all origins are allowed)
# CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# PORT=4000
